# Start message shown when user sends /start
# Supported dynamic variables: {first} {last} {id} {mention} {username}
START_MESSAGE=<b>Hello {first} 👋 Welcome!</b>
# Message shown when user has not joined required channel (force sub message)
# Same dynamic variables supported as above
FORCE_SUB_MESSAGE=<b>Please join our channel to use the bot.</b>
# Image sent along with start message (URL or local file path)
START_PIC=https://i.ibb.co/QvCr3dYy/1771910931555.jpg
# Prevent users from forwarding or saving files
# True = protected content, False = normal
PROTECT_CONTENT=True
# Auto delete time in seconds for sent files
# Example: 300 = 5 minutes
# Use 0 or False to disable auto deletion
AUTO_DELETE_TIME=0
# Message shown before file gets auto deleted
AUTO_DELETE_MSG=⚠️ Due to of copyright © infrigment,This file will be deleted automatically after 5 minutes.
# Message shown after file is successfully deleted
AUTO_DEL_SUCCESS_MSG=✅ File deleted successfully.
# Enable join request system for channel
# True = users send join request instead of direct join
JOIN_REQUEST_ENABLED=False
# Custom caption for documents sent by bot
# Supported variables: {filename} {previouscaption}
CUSTOM_CAPTION=<b>{filename}</b>\n\n{previouscaption}
# Disable channel share button below messages
# True = hide button, False = show button
DISABLE_CHANNEL_BUTTON=False
# Custom text for /stats command
# Supported variable: {uptime}
BOT_STATS_TEXT=<b>Bot Uptime:</b> {uptime}
# Message shown when user sends any message to bot
USER_REPLY_TEXT=<b>Processing your request...</b>